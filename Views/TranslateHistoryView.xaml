<UserControl x:Class="BlankApp.Views.TranslateHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BlankApp.Views"
             mc:Ignorable="d" 
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ListBox ItemsSource="{Binding HistoryList}">
            <!-- 定义每一个条目的长相 -->
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- 边界修饰，让每个历史记录看起来像一个小卡片 -->
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8" Width="240">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- 放原文 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 放译文 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 放时间 -->
                            </Grid.RowDefinitions>

                            <!-- 1. 原文：加粗，前景色稍微深一点 -->
                            <TextBlock Grid.Row="0" 
                               Text="{Binding OriginalText}" 
                               FontWeight="Bold" 
                               Foreground="#333333" 
                               TextWrapping="Wrap"/>

                            <!-- 2. 译文：常规字体，加一点顶部边距隔开 -->
                            <TextBlock Grid.Row="1" 
                               Text="{Binding TranslatedText}" 
                               Foreground="#666666" 
                               Margin="0,4,0,0" 
                               TextWrapping="Wrap"/>

                            <!-- 3. 时间：字号小一点，靠右对齐，颜色淡一点 -->
                            <TextBlock Grid.Row="2" 
                               Text="{Binding TimeStamp}" 
                               FontSize="10" 
                               Foreground="#999999" 
                               HorizontalAlignment="Right" 
                               Margin="0,6,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
